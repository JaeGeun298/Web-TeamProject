{{> layouts/header}}

<h2>여행 수정</h2>

<form action="/trips/{{tripId}}/edit" method="post">
    <input type="text" name="title" value="{{title}}" placeholder="여행 이름" required/>
    <input type="date" name="startDate" value="{{startDate}}"/>
    <input type="date" name="endDate" value="{{endDate}}"/>
    <input type="text" name="description" value="{{description}}" placeholder="설명"/>
    <button type="submit">저장</button>
</form>

{{> layouts/footer}}