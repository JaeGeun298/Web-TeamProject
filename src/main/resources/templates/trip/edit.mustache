{{> layouts/header}}
{{> layouts/gnb}}

<div class="container mt-5 mb-5" style="max-width: 600px;">
    <h2 class="fw-bold mb-4">여행 수정</h2>

    <div class="card shadow-sm">
        <div class="card-body p-4">
            <form action="/trips/{{tripId}}/edit" method="post">
                <div class="mb-3">
                    <label class="form-label fw-bold">여행 이름</label>
                    <input type="text" name="title" class="form-control" value="{{title}}" placeholder="여행 이름" required/>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">시작일</label>
                    <input type="date" name="startDate" class="form-control" value="{{startDate}}"/>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">종료일</label>
                    <input type="date" name="endDate" class="form-control" value="{{endDate}}"/>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold">설명</label>
                    <input type="text" name="description" class="form-control" value="{{description}}" placeholder="설명 (선택)"/>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">저장</button>
                    <a href="/trips" class="btn btn-outline-secondary px-4">취소</a>
                </div>
            </form>
        </div>
    </div>
</div>

{{> layouts/footer}}
