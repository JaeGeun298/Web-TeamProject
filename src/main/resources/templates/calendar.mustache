{{>layouts/header}}

<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400&family=Poppins:wght@300;400;500&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/@fullcalendar/core@4.4.2/main.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/@fullcalendar/daygrid@4.4.2/main.min.css" rel="stylesheet">

<style>
  body {
    font-family: "Roboto", -apple-system, BlinkMacSystemFont, "Segoe UI",
                 "Helvetica Neue", Arial, sans-serif;
    background-color: #efefef;
  }

  #calendar-container {
    padding: 20px;
    min-height: calc(100vh - 80px);
  }

  #calendar {
    height: calc(100vh - 130px);
  }
  #calendar .fc-view-container {
    background-color: #fff;
    box-shadow: 0 15px 30px 0 rgba(0, 0, 0, 0.2);
  }
  .fc-header-toolbar {
    padding: 1em 1em 0;
  }

  #calendar .fc-toolbar.fc-header-toolbar .fc-center {
    display: block;
  }

  .fc-button-primary {
    background-color: #3d8ef8 !important;
    border-color: #3d8ef8 !important;
    border-radius: 4px !important;
    font-size: 0.85rem;
    padding: 4px 12px;
    transition: background-color 0.2s;
  }
  .fc-button-primary:hover {
    background-color: #2a74d6 !important;
    border-color: #2a74d6 !important;
  }
  .fc-button-primary:focus {
    box-shadow: none !important;
  }

  .fc-toolbar h2 {
    font-family: "Poppins", sans-serif;
    font-size: 1.25rem;
    font-weight: 500;
    color: #333;
  }

  .fc-day:hover {
    background-color: #f5f8ff;
  }

  .fc-event {
    border: none !important;
    border-radius: 3px;
    font-size: 0.78rem;
    padding: 1px 4px;
    cursor: pointer;
  }

  .event-trip { background-color: #3d8ef8 !important; }

  @media (max-width: 767px) {
    .fc-toolbar {
      display: block !important;
      text-align: center;
    }
    .fc-toolbar .fc-center {
      display: block;
      margin: 10px 0;
    }
  }
</style>

{{>layouts/gnb}}

<div id="calendar-container">
  <div id="calendar"></div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@fullcalendar/core@4.4.2/main.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@fullcalendar/daygrid@4.4.2/main.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@fullcalendar/interaction@4.4.2/main.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@fullcalendar/core@4.4.2/locales/ko.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var calendarEl = document.getElementById('calendar');

        var calendar = new FullCalendar.Calendar(calendarEl, {
            plugins: ['dayGrid', 'interaction'],
            locale: 'ko',
            height: 'parent',

            header: {
                left:   'prev,next',
                center: 'title',
                right:  ''
            },

            defaultView: 'dayGridMonth',

            eventSources: [
                {
                    url: '/api/trips/calendar',
                    failure: function () {
                        console.error('캘린더 이벤트 로드 실패');
                    }
                },
                {
                    url: '/api/expenses/trip/{{#tripId}}{{tripId}}{{/tripId}}{{^tripId}}1{{/tripId}}',
                    failure: function () {
                        console.error('지출 이벤트 로드 실패');
                    }
                }
            ],

            eventRender: function (info) {
                if (!info.event.backgroundColor || info.event.backgroundColor !== '#ff9f89') {
                    info.el.classList.add('event-trip');
                }
            },

            dateClick: function (info) {
                window.location.href = '/expenses/trip/{{#tripId}}{{tripId}}{{/tripId}}{{^tripId}}1{{/tripId}}?date=' + info.dateStr;
            },

            eventClick: function (info) {
                // Get local YYYY-MM-DD string
                var localDate = info.event.start.getFullYear() + '-' + 
                                String(info.event.start.getMonth() + 1).padStart(2, '0') + '-' + 
                                String(info.event.start.getDate()).padStart(2, '0');
                
                if (info.event.backgroundColor === '#ff9f89') {
                    window.location.href = '/expenses/trip/{{#tripId}}{{tripId}}{{/tripId}}{{^tripId}}1{{/tripId}}?date=' + localDate;
                } else {
                    window.location.href = '/expenses/trip/' + info.event.id;
                }
            }
        });

        calendar.render();
    });
</script>

{{>layouts/footer}}
