{{> layouts/header}}
{{> layouts/gnb}}
<div class="container mt-5 mb-5">
    <h2 class="mb-4 fw-bold">지출 내역 목록 {{#selectedDate}}({{selectedDate}}){{/selectedDate}}</h2>

    <div class="card shadow-sm mb-5">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 text-center align-middle">
                <thead class="table-light">
                <tr>
                    <th>날짜</th>
                    <th>항목</th>
                    <th>결제자</th>
                    <th>금액</th>
                    <th>관리</th>
                </tr>
                </thead>
                <tbody>
                {{#expenses}}
                    <tr>
                        <td>{{travelDate}}</td>
                        <td>{{title}}</td>
                        <td>{{payer}}</td>
                        <td>{{price}}원</td>
                        <td>
                            <form action="/expenses/{{id}}/delete" method="post" class="d-inline">
                                <input type="hidden" name="tripId" value="{{tripId}}">
                                <button type="submit" class="btn btn-danger btn-sm">삭제</button>
                            </form>
                        </td>
                    </tr>
                {{/expenses}}
                {{^expenses}}
                    <tr>
                        <td colspan="5" class="py-4 text-muted">지출 내역이 없습니다.</td>
                    </tr>
                {{/expenses}}
                </tbody>
            </table>
        </div>
    </div>

    <h3 class="mb-3 fw-bold">지출 등록</h3>
    <div class="card shadow-sm bg-light">
        <div class="card-body p-4">
            <form action="/expenses/create" method="post" class="row g-3">
                <input type="hidden" name="tripId" value="{{tripId}}">

                <div class="col-md-3">
                    <input type="date" name="travelDate" class="form-control" value="{{#selectedDate}}{{selectedDate}}{{/selectedDate}}" required>
                </div>
                <div class="col-md-3">
                    <input type="text" name="title" class="form-control" placeholder="항목" required>
                </div>
                <div class="col-md-2">
                    <input type="text" name="payer" class="form-control" placeholder="결제자" required>
                </div>
                <div class="col-md-3">
                    <input type="number" name="price" class="form-control" placeholder="금액" required>
                </div>
                <div class="col-md-1 d-grid">
                    <button type="submit" class="btn btn-primary">등록</button>
                </div>
            </form>
        </div>
    </div>
</div>
{{> layouts/footer}}